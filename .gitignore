# .gitignore — Saman Digital

# Dependencias
node_modules/
.pnp
.pnp.js

# Base de datos (IMPORTANTE: incluir en backups manuales)
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-journal

# Archivos de entorno (contienen secretos)
.env
.env*.local

# Archivos de build
.next/
out/
dist/

# Caché y logs
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Variables de sistema
.DS_Store
Thumbs.db
*.pem

# Archivos de backup (archivos .zip locales)
backups/*.zip

# Logs
logs/
*.log

# Coverage de tests
coverage/
.nyc_output

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Archivos de editor
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
