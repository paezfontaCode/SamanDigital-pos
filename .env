# ============================================================
# VARIABLES DE ENTORNO — SAMAN DIGITAL
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Edita los valores según tu configuración
# ============================================================

# Base de datos SQLite (no cambiar la ruta)
DATABASE_URL="file:./dev.db"

# Secreto para NextAuth.js (cambiar por una clave aleatoria segura)
# Generar con: openssl rand -base64 32
AUTH_SECRET="CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_ALEATORIA"

# URL base de la aplicación
# En desarrollo: http://localhost:3000
# En producción LAN: http://IP_DEL_SERVIDOR:3000
NEXTAUTH_URL="http://localhost:3000"

# Puerto del servidor (opcional, default: 3000)
PORT=3000

# Modo de la aplicación
NODE_ENV="development"

# ============================================================
# CONFIGURACIÓN DEL NEGOCIO (también configurable desde la UI)
# ============================================================
BUSINESS_NAME="Saman Digital"
BUSINESS_PHONE=""
BUSINESS_ADDRESS=""
BUSINESS_TAX_ID=""
